<?xml version="1.0" encoding="UTF-8"?>
<config>
  <adapter_name>BAYESADAPTER</adapter_name>
  <initialization>BAYESADAPTER</initialization>

  <bayesadapter_prior_sigma>0.01</bayesadapter_prior_sigma>
  <bayesadapter_train_mc_samples>3</bayesadapter_train_mc_samples>
  <bayesadapter_eval_mc_samples>10</bayesadapter_eval_mc_samples>
  <bayesadapter_kl_scale_divisor>1000.0</bayesadapter_kl_scale_divisor>

  <!-- paper_scalar / diag -->
  <bayesadapter_covariance_mode>paper_scalar</bayesadapter_covariance_mode>

  <!-- text-only bridge source -->
  <bayesadapter_text_only_ckpt>last</bayesadapter_text_only_ckpt>
  <bayesadapter_text_only_run_dir_template>{save_dir}/text_only_bayes_coop_bayes/{dataset}/shot_{shots_per_class}/seed_{seed}</bayesadapter_text_only_run_dir_template>

  <!-- replace / blend -->
  <bayesadapter_text_only_mu_strategy>blend</bayesadapter_text_only_mu_strategy>
  <bayesadapter_text_only_mu_blend_lambda>0.0</bayesadapter_text_only_mu_blend_lambda>

  <!-- ignore / override -->
  <bayesadapter_text_only_sigma_strategy>override</bayesadapter_text_only_sigma_strategy>
</config>