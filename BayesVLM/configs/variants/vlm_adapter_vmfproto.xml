<?xml version="1.0" encoding="UTF-8"?>
<config>
  <variant>VMFPROTO</variant>
  <initialization>ZS</initialization>

  <!-- training-free -->
  <epochs>0</epochs>
  <train_logit_scale>false</train_logit_scale>

  <!-- BayesVLM Hessian / covariance directory -->
  <hessian_dir>./hessians/hessian_CLIP-ViT-B-32-laion2B-s34B-b79K</hessian_dir>

  <!-- kappa = alpha / (rho + eps) -->
  <vmf_kappa_scale>0.05</vmf_kappa_scale>
  <vmf_eps>1e-6</vmf_eps>

  <!-- 中文说明：
       为了避免 rho 很小时 kappa 爆炸，先加一个上界。
       第一轮建议先用 500。 -->
  <vmf_kappa_max>500.0</vmf_kappa_max>
</config>