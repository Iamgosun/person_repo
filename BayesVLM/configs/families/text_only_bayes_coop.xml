<?xml version="1.0" encoding="UTF-8"?>
<config>
  <family>text_only_bayes_coop</family>
  <output_name>text_only_bayes_coop_bayes</output_name>
  <variant>default</variant>
  <n_ctx>16</n_ctx>
  <ctx_init></ctx_init>
  <csc>false</csc>
  <class_token_position>end</class_token_position>

  <hessian_dir>./hessians/hessian_CLIP-ViT-B-32-laion2B-s34B-b79K</hessian_dir>
  <pseudo_data_count>4</pseudo_data_count>
  <lambda_txt_init>300.0</lambda_txt_init>
  <lambda_opt_steps>1000</lambda_opt_steps>

  <use_full_cov>false</use_full_cov>
  <train_objective>bayes</train_objective>
  <hybrid_warmup_epochs>5</hybrid_warmup_epochs>
  <map_loss_weight>1.0</map_loss_weight>
  <bayes_loss_weight>1.0</bayes_loss_weight>
  <ctx_reg_weight>1e-4</ctx_reg_weight>

  
  <save_prototype_history>false</save_prototype_history>
  <prototype_track_class_ids>
    <item>0</item><item>1</item><item>2</item><item>3</item><item>4</item>
    <item>5</item><item>6</item><item>7</item><item>8</item><item>9</item>
  </prototype_track_class_ids>
</config>
